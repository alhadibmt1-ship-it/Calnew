{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "calculator24",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/public", // This points specifically to your built frontend
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
